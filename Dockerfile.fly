FROM golang:1.26.4-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/co ./cmd/co

FROM alpine:3
RUN apk add --no-cache bind-tools
COPY --from=build /bin/co /bin/co
COPY fly-init.sh /bin/fly-init.sh
RUN chmod +x /bin/fly-init.sh
ENTRYPOINT ["/bin/fly-init.sh"]
