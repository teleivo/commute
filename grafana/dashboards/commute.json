{
  "title": "Commute",
  "uid": "commute",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "GCounter increments per node",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "commute_gcounter_node_increments",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": { "mode": "normal", "group": "A" },
            "gradientMode": "none"
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ]
}
