{
  "title": "Commute CRDT",
  "uid": "commute",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "sort": 0
      },
      {
        "name": "key",
        "label": "Key",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(commute_gcounter_node_increments, key)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      },
      {
        "name": "region",
        "label": "Region",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(commute_gcounter_node_increments{key=\"$key\"}, region)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "GCounter increments per node (scraping $region)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "expr": "commute_gcounter_node_increments{key=\"$key\"}",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "gradientMode": "none"
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ]
}
